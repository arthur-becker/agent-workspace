# Copy to .env (or paste these into Dokploy's Environment settings).

# --- SSH access (paths 1 & 2: ssh + VS Code Remote-SSH) ---
# One or more PUBLIC keys, newline-separated. Get yours with: cat ~/.ssh/id_ed25519.pub
AUTHORIZED_KEYS="ssh-ed25519 AAAA... you@laptop"
# Optional password fallback for the `agent` user. Leave empty for key-only (recommended).
SSH_PASSWORD=""
# Host port Dokploy publishes for SSH (container listens on 22).
SSH_PUBLISH_PORT="2222"

# --- code-server (path 3: browser VS Code) ---
# Password for the browser login screen. Leave empty only if you front it with Dokploy auth.
CODE_SERVER_PASSWORD="change-me-to-something-strong"

# --- Claude Code auth (optional) ---
# Set for non-interactive auth, or leave empty and run `claude` to log in interactively.
ANTHROPIC_API_KEY=""
