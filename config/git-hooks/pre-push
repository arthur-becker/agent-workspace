#!/usr/bin/env bash
# Defense-in-depth: block force pushes (non-fast-forward) and remote ref deletions.
#
# Installed system-wide via `git config --system core.hooksPath /etc/git-hooks`.
# Scope: enforced ONLY for the `agent` user; the human `admin` is unrestricted and
# can force-push freely. (In practice the agent can't push at all — the git wrapper
# and lack of credentials stop it first — so this is a belt-and-suspenders backstop.)
# CAVEAT: a hook is bypassable with `git push --no-verify` and by `sudo`. This stops
# ACCIDENTAL history rewrites, not a determined actor. The real guarantee is branch
# protection on the remote. See SECURITY.md.
set -uo pipefail

# Admin / root / anyone but the agent: allow everything.
[[ "$(id -un)" != "agent" ]] && exit 0

zero="0000000000000000000000000000000000000000"
status=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Deleting a remote ref (pushing nothing to an existing remote ref).
  if [[ "$local_sha" == "$zero" ]]; then
    echo "pre-push: refusing to DELETE remote ref $remote_ref" >&2
    status=1
    continue
  fi

  # Brand-new remote ref — always a fast-forward, allow.
  [[ "$remote_sha" == "$zero" ]] && continue

  # Non-fast-forward = the remote tip is not an ancestor of what we're pushing.
  if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
    echo "pre-push: refusing NON-FAST-FORWARD (force) push to $remote_ref" >&2
    status=1
  fi
done

[[ $status -ne 0 ]] && echo "pre-push: blocked. Use the remote's PR/merge flow instead." >&2
exit $status
